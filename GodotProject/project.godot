; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Solar-XR"
run/main_scene="res://content/scenes/main/main.tscn"
config/features=PackedStringArray("4.5", "Mobile")
config/icon="res://icon.svg"

[autoload]

XRToolsUserSettings="*res://addons/godot-xr-tools/user_settings/user_settings.gd"
XRToolsRumbleManager="*res://addons/godot-xr-tools/rumble/rumble_manager.gd"
TouchManager="*res://addons/mars-ui/lib/utils/touch/touch.gd"
EventSystem="*res://addons/mars-ui/lib/globals/event_system.gd"

[debug]

gdscript/warnings/integer_division=0

[display]

window/vsync/vsync_mode=0

[editor_plugins]

enabled=PackedStringArray("res://addons/godot-xr-tools/plugin.cfg", "res://addons/mars-ui/plugin.cfg")

[filesystem]

import/blender/enabled=false

